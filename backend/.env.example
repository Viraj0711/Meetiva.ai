# Application
NODE_ENV=development
PORT=8000

# Database (Supabase)
# Get from: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:5174
FRONTEND_APP_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=524288000
UPLOAD_DIR=./uploads

# AI Features (Optional)
OPENAI_API_KEY=sk-your-openai-api-key
GROK_API_KEY=xai-your-grok-api-key
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# Google OAuth + Calendar (Required for calendar integration)
# Scopes requested by backend:
# - https://www.googleapis.com/auth/calendar.events
# - https://www.googleapis.com/auth/userinfo.profile
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# 32-byte key for AES-256-GCM token encryption.
# Use one of: 64-char hex, 32-byte raw string, or base64 of 32 bytes.
# Example generation (PowerShell):
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
GOOGLE_TOKEN_ENCRYPTION_KEY=base64-or-hex-32-byte-key

# Email notifications (Optional but required for email deadline alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@meetiva.ai
