generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  name               String
  hashedPassword     String
  isActive           Boolean          @default(true)
  isVerified         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  meetings           Meeting[]
  actionItems        ActionItem[]
  teamMembers        TeamMember[]
  invitedByRelations TeamMember[]     @relation("InvitedBy")
  sentInvitations    TeamInvitation[]
  googleCalendarAuth GoogleCalendarAuth?
  notifications      Notification[]
  teamChatMessages   TeamChatMessage[]

  @@map("users")
}

enum MeetingStatus {
  uploading
  processing
  transcribing
  analyzing
  completed
  failed
}

enum MeetingPriority {
  low
  medium
  high
  urgent
}

enum ActionItemStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TeamRole {
  MANAGER
  LEAD
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Meeting {
  id                 String          @id @default(uuid())
  title              String
  description        String?
  status             MeetingStatus   @default(uploading)
  priority           MeetingPriority @default(medium)
  audioUrl           String?
  videoUrl           String?
  duration           Int?
  participants       Json            @default("[]")
  processingProgress Int?            @default(0)
  userId             String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  completedAt        DateTime?
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary            MeetingSummary?
  transcript         Transcript?
  actionItems        ActionItem[]

  @@index([userId, createdAt])
  @@map("meetings")
}

model MeetingSummary {
  id               String   @id @default(uuid())
  meetingId        String   @unique
  executiveSummary String
  keyPoints        Json     @default("[]")
  decisions        Json     @default("[]")
  openQuestions    Json     @default("[]")
  sentiment        String   @default("neutral")
  createdAt        DateTime @default(now())
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_summaries")
}

model Transcript {
  id        String   @id @default(uuid())
  meetingId String   @unique
  segments  Json     @default("[]")
  fullText  String
  language  String   @default("en")
  createdAt DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

model ActionItem {
  id          String           @id @default(uuid())
  meetingId   String
  userId      String
  title       String
  description String?
  assignee    String?
  dueDate     DateTime?
  priority    MeetingPriority  @default(medium)
  status      ActionItemStatus @default(pending)
  tags        Json             @default("[]")
  reminderSentAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  completedAt DateTime?
  meeting     Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([userId, status])
  @@index([meetingId])
  @@map("action_items")
}

model Team {
  id          String           @id @default(uuid())
  name        String
  description String?
  managerId   String? // ID of the manager who created this team
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  teamMembers TeamMember[]
  invitations TeamInvitation[]
  chatMessages TeamChatMessage[]

  @@index([managerId])
  @@map("teams")
}

model TeamChatMessage {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@index([userId])
  @@map("team_chat_messages")
}

model TeamMember {
  id         String           @id @default(uuid())
  userId     String
  teamId     String
  role       TeamRole         @default(MEMBER)
  status     InvitationStatus @default(ACCEPTED)
  invitedBy  String? // userId of who invited this person
  invitedAt  DateTime?
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter    User?            @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([userId])
  @@index([status])
  @@map("team_members")
}

model TeamInvitation {
  id        String           @id @default(uuid())
  email     String
  teamId    String
  role      TeamRole         @default(MEMBER)
  invitedBy String
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  expiresAt DateTime
  team      Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter   User             @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([email, teamId])
  @@index([email])
  @@index([teamId])
  @@map("team_invitations")
}

model GoogleCalendarAuth {
  id                  String   @id @default(uuid())
  userId              String   @unique
  encryptedAccessToken String
  encryptedRefreshToken String
  tokenType           String?  @default("Bearer")
  scope               String?
  expiryDate          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiryDate])
  @@map("google_calendar_auth")
}

enum NotificationType {
  DEADLINE_REMINDER
  SYSTEM
}

model Notification {
  id           String           @id @default(uuid())
  userId       String
  actionItemId String?
  type         NotificationType @default(SYSTEM)
  title        String
  message      String
  channel      String           @default("in_app")
  isRead       Boolean          @default(false)
  readAt       DateTime?
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionItem   ActionItem?      @relation(fields: [actionItemId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([actionItemId])
  @@map("notifications")
}
